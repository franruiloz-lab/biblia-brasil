---
import Base from './Base.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import VersoesComparacao from '../components/biblia/VersoesComparacao.astro';
import FAQVersiculo from '../components/biblia/FAQVersiculo.astro';
import VersiculosRelacionados from '../components/biblia/VersiculosRelacionados.astro';

interface Versoes {
  ARC: string;
  'NVI-PT': string;
  NTLH: string;
  NVT: string;
}

interface FAQItem {
  pergunta: string;
  resposta: string;
}

interface RelatedVerse {
  ref: string;
  texto: string;
}

interface Props {
  livroNome: string;
  livroSlug: string;
  capitulo: number;
  versiculoNumero: number;
  referencia: string;         // ex: "Salmos 91:7"
  versoesTexto: Versoes;
  versoesRelacionados: RelatedVerse[];
  faqItems: FAQItem[];
  temas: string[];
  explicacaoIntro?: string;
  contextoPassagem?: {
    antes?: { numero: number; texto: string }[];
    depois?: { numero: number; texto: string }[];
  };
}

const {
  livroNome, livroSlug, capitulo, versiculoNumero,
  referencia, versoesTexto, versoesRelacionados,
  faqItems, temas, explicacaoIntro, contextoPassagem
} = Astro.props;

const title = `${referencia} — Versículo da Bíblia em 4 versões | Bíblia Brasil`;
const description = `${versoesTexto.ARC} — ${referencia}. Veja em 4 versões (ARC, NVI, NTLH, NVT), explicação completa e versículos relacionados.`;

// Schema Article + FAQPage
const schemaArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `${referencia} — Significado e versões`,
  "description": description,
  "inLanguage": "pt-BR",
  "about": {
    "@type": "Thing",
    "name": referencia
  },
  "publisher": {
    "@type": "Organization",
    "name": "Bíblia Brasil",
    "url": "https://bibliabrasil.com.br"
  }
};

const schemaFAQ = faqItems.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.pergunta,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.resposta
    }
  }))
} : null;

const breadcrumbs = [
  { label: 'Início', href: '/' },
  { label: 'A Bíblia', href: '/biblia/' },
  { label: livroNome, href: `/biblia/${livroSlug}/` },
  { label: `Capítulo ${capitulo}`, href: `/biblia/${livroSlug}/${capitulo}/` },
  { label: `Versículo ${versiculoNumero}` },
];
---

<Base
  title={title}
  description={description}
  schema={schemaFAQ ? [schemaArticle, schemaFAQ] : schemaArticle}
>
  <article class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbs} />

    <!-- Header do versículo -->
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        {temas.slice(0, 3).map(tema => (
          <a href={`/temas/${tema}/`} class="badge hover:bg-purple-100 transition-colors">
            {tema.replace(/-/g, ' ')}
          </a>
        ))}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-2">
        {referencia}
      </h1>
      <p class="text-lg leading-relaxed" style="color: var(--color-text-muted);">
        {versoesTexto.ARC}
      </p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_260px] gap-10">
      <!-- Coluna principal -->
      <div>
        <!-- Comparação de versões (nossa vantagem principal) -->
        <section class="mb-10" aria-labelledby="versoes-heading">
          <h2 id="versoes-heading" class="text-xl font-bold mb-4">
            {referencia} em 4 versões
          </h2>
          <VersoesComparacao versoes={versoesTexto} referencia={referencia} />
        </section>

        <!-- Contexto da passagem -->
        {contextoPassagem && (contextoPassagem.antes?.length || contextoPassagem.depois?.length) && (
          <section class="mb-10" aria-labelledby="contexto-heading">
            <h2 id="contexto-heading" class="text-xl font-bold mb-4">
              Contexto da passagem
            </h2>
            <div class="rounded-xl p-5 border" style="border-color: var(--color-border); background-color: var(--color-bg-card);">
              {contextoPassagem.antes?.map(v => (
                <div class="flex gap-3 mb-3 opacity-60">
                  <span class="ui-font text-xs font-bold mt-1 w-5 flex-shrink-0" style="color: var(--color-text-muted);">{v.numero}</span>
                  <p class="verse-text text-sm">{v.texto}</p>
                </div>
              ))}
              <div class="flex gap-3 mb-3 py-2 px-3 rounded-lg" style="background-color: var(--color-verse-bg);">
                <span class="ui-font text-xs font-bold mt-1 w-5 flex-shrink-0" style="color: var(--color-primary);">{versiculoNumero}</span>
                <p class="verse-text text-sm font-semibold">{versoesTexto.ARC}</p>
              </div>
              {contextoPassagem.depois?.map(v => (
                <div class="flex gap-3 mb-3 opacity-60">
                  <span class="ui-font text-xs font-bold mt-1 w-5 flex-shrink-0" style="color: var(--color-text-muted);">{v.numero}</span>
                  <p class="verse-text text-sm">{v.texto}</p>
                </div>
              ))}
            </div>
            <p class="ui-font text-xs mt-2 text-center" style="color: var(--color-text-muted);">
              <a href={`/biblia/${livroSlug}/${capitulo}/`} class="hover:text-purple-600 underline">
                Ver o capítulo {capitulo} completo →
              </a>
            </p>
          </section>
        )}

        <!-- Explicação / slot para conteúdo editorial -->
        {explicacaoIntro && (
          <section class="mb-10" aria-labelledby="explicacao-heading">
            <h2 id="explicacao-heading" class="text-xl font-bold mb-4">
              O que significa {referencia}?
            </h2>
            <div class="prose-biblia text-base leading-relaxed space-y-4" style="color: var(--color-text);">
              <p>{explicacaoIntro}</p>
              <slot name="explicacao" />
            </div>
          </section>
        )}

        <!-- FAQ -->
        {faqItems.length > 0 && <FAQVersiculo items={faqItems} />}

        <!-- Versículos relacionados -->
        {versoesRelacionados.length > 0 && <VersiculosRelacionados versiculos={versoesRelacionados} />}

        <!-- CTA: ver capítulo completo -->
        <div class="mt-12 p-6 rounded-2xl text-center" style="background-color: var(--color-verse-bg);">
          <p class="ui-font font-semibold mb-3" style="color: var(--color-text);">
            Leia o capítulo completo
          </p>
          <a
            href={`/biblia/${livroSlug}/${capitulo}/`}
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-semibold text-sm ui-font text-white transition-all hover:opacity-90"
            style="background-color: var(--color-primary);"
          >
            {livroNome} {capitulo} completo →
          </a>
        </div>
      </div>

      <!-- Sidebar / TOC -->
      <aside class="hidden lg:block">
        <div class="sticky top-20 space-y-6">
          <!-- Navegação do versículo -->
          <div class="rounded-xl p-4 border" style="border-color: var(--color-border); background-color: var(--color-bg-card);">
            <h3 class="ui-font text-sm font-bold mb-3" style="color: var(--color-text);">Nesta página</h3>
            <nav class="space-y-1">
              <a href="#versoes-heading" class="toc-link">Versões da Bíblia</a>
              {(contextoPassagem?.antes?.length || contextoPassagem?.depois?.length) && (
                <a href="#contexto-heading" class="toc-link">Contexto da passagem</a>
              )}
              {explicacaoIntro && <a href="#explicacao-heading" class="toc-link">Significado</a>}
              {faqItems.length > 0 && <a href="#faq-heading" class="toc-link">Perguntas frequentes</a>}
              {versoesRelacionados.length > 0 && <a href="#related-heading" class="toc-link">Versículos relacionados</a>}
            </nav>
          </div>

          <!-- Compartilhar -->
          <div class="rounded-xl p-4 border" style="border-color: var(--color-border); background-color: var(--color-bg-card);">
            <h3 class="ui-font text-sm font-bold mb-3" style="color: var(--color-text);">Compartilhar</h3>
            <div class="flex flex-col gap-2">
              <a
                href={`https://api.whatsapp.com/send?text=${encodeURIComponent(`"${versoesTexto.ARC}" — ${referencia} | Bíblia Brasil`)}`}
                target="_blank"
                rel="noopener"
                class="btn-share btn-whatsapp justify-center"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp
              </a>
            </div>
          </div>

          <!-- Versões info -->
          <div class="rounded-xl p-4 border" style="border-color: var(--color-border); background-color: var(--color-bg-card);">
            <h3 class="ui-font text-sm font-bold mb-3" style="color: var(--color-text);">Versões disponíveis</h3>
            <ul class="space-y-1 ui-font text-xs" style="color: var(--color-text-muted);">
              <li>• <strong>ARC</strong> — Almeida Revisada e Corrigida</li>
              <li>• <strong>NVI</strong> — Nova Versão Internacional</li>
              <li>• <strong>NTLH</strong> — Linguagem de Hoje</li>
              <li>• <strong>NVT</strong> — Nova Versão Transformadora</li>
            </ul>
          </div>
        </div>
      </aside>
    </div>
  </article>
</Base>
