---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object | object[];
}

const { title, description, canonical, ogImage, schema } = Astro.props;
const siteUrl = 'https://bibliabrasil.com.br';
const canonicalUrl = canonical || Astro.url.href;
const ogImg = ogImage || `${siteUrl}/og-default.jpg`;
---

<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:site_name" content="Bíblia Brasil" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImg} />

  <!-- Schema -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(schema) ? schema : [schema])} />
  )}

  <!-- Schema base do site -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Bíblia Brasil",
    "url": siteUrl,
    "description": "A Bíblia Sagrada em português com versículos, explicações e estudos bíblicos",
    "inLanguage": "pt-BR",
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${siteUrl}/buscar?q={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
</head>
<body>
  <!-- Nav -->
  <header class="sticky top-0 z-50 border-b ui-font" style="background-color: var(--color-bg-card); border-color: var(--color-border);">
    <div class="max-w-5xl mx-auto px-4 flex items-center justify-between h-14">
      <a href="/" class="flex items-center gap-2 font-bold text-lg" style="color: var(--color-primary);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
        </svg>
        Bíblia Brasil
      </a>

      <nav class="hidden md:flex items-center gap-6 text-sm font-medium" style="color: var(--color-text-muted);">
        <a href="/biblia" class="hover:text-purple-600 transition-colors">A Bíblia</a>
        <a href="/temas" class="hover:text-purple-600 transition-colors">Temas</a>
        <a href="/salmos" class="hover:text-purple-600 transition-colors">Salmos</a>
        <a href="/buscar" class="hover:text-purple-600 transition-colors">Buscar</a>
      </nav>

      <div class="flex items-center gap-2">
        <!-- Dark mode toggle -->
        <button
          id="theme-toggle"
          aria-label="Alternar modo escuro"
          class="p-2 rounded-lg transition-colors hover:bg-gray-100 dark:hover:bg-gray-800"
          style="color: var(--color-text-muted);"
        >
          <svg id="icon-sun" class="hidden w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
          </svg>
          <svg id="icon-moon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
        </button>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg" style="color: var(--color-text-muted);" aria-label="Menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden px-4 pb-3 ui-font" style="border-top: 1px solid var(--color-border);">
      <nav class="flex flex-col gap-2 pt-3 text-sm font-medium" style="color: var(--color-text-muted);">
        <a href="/biblia" class="py-1">A Bíblia</a>
        <a href="/temas" class="py-1">Temas</a>
        <a href="/salmos" class="py-1">Salmos</a>
        <a href="/buscar" class="py-1">Buscar</a>
      </nav>
    </div>
  </header>

  <!-- Main content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="mt-16 py-10 border-t ui-font" style="background-color: var(--color-bg-card); border-color: var(--color-border); color: var(--color-text-muted);">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-8">
        <div>
          <h3 class="font-bold text-sm mb-3" style="color: var(--color-text);">A Bíblia</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/biblia" class="hover:text-purple-600 transition-colors">Todos os livros</a></li>
            <li><a href="/salmos" class="hover:text-purple-600 transition-colors">Salmos</a></li>
            <li><a href="/biblia/proverbios" class="hover:text-purple-600 transition-colors">Provérbios</a></li>
            <li><a href="/biblia/mateus" class="hover:text-purple-600 transition-colors">Mateus</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-sm mb-3" style="color: var(--color-text);">Temas</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/temas/fe" class="hover:text-purple-600 transition-colors">Fé</a></li>
            <li><a href="/temas/protecao" class="hover:text-purple-600 transition-colors">Proteção</a></li>
            <li><a href="/temas/familia" class="hover:text-purple-600 transition-colors">Família</a></li>
            <li><a href="/temas/paz" class="hover:text-purple-600 transition-colors">Paz</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-sm mb-3" style="color: var(--color-text);">Versículos</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/biblia/salmos/91" class="hover:text-purple-600 transition-colors">Salmo 91</a></li>
            <li><a href="/biblia/proverbios/16/3" class="hover:text-purple-600 transition-colors">Provérbios 16:3</a></li>
            <li><a href="/biblia/numeros/6/24" class="hover:text-purple-600 transition-colors">Números 6:24-26</a></li>
            <li><a href="/biblia/romanos/8/28" class="hover:text-purple-600 transition-colors">Romanos 8:28</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-sm mb-3" style="color: var(--color-text);">Sobre</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/buscar" class="hover:text-purple-600 transition-colors">Buscar versículos</a></li>
            <li><a href="/sobre" class="hover:text-purple-600 transition-colors">Sobre nós</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t pt-6 text-center text-xs" style="border-color: var(--color-border);">
        <p>&copy; {new Date().getFullYear()} Bíblia Brasil — A Palavra de Deus para o povo brasileiro</p>
      </div>
    </div>
  </footer>

  <script>
    // Dark mode
    const toggle = document.getElementById('theme-toggle');
    const html = document.documentElement;
    const iconSun = document.getElementById('icon-sun');
    const iconMoon = document.getElementById('icon-moon');

    const saved = localStorage.getItem('theme') || 'light';
    html.dataset.theme = saved;
    updateIcons(saved);

    toggle?.addEventListener('click', () => {
      const current = html.dataset.theme || 'light';
      const next = current === 'light' ? 'dark' : 'light';
      html.dataset.theme = next;
      localStorage.setItem('theme', next);
      updateIcons(next);
    });

    function updateIcons(theme: string) {
      if (theme === 'dark') {
        iconSun?.classList.remove('hidden');
        iconMoon?.classList.add('hidden');
      } else {
        iconSun?.classList.add('hidden');
        iconMoon?.classList.remove('hidden');
      }
    }

    // Mobile menu
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
