---
// CookieBanner.astro — GDPR cookie consent banner
---

<div
  id="cookie-banner"
  role="dialog"
  aria-label="Aviso de cookies"
  aria-live="polite"
  class="cookie-banner ui-font"
  style="display: none;"
>
  <div class="cookie-banner__inner">
    <div class="cookie-banner__text">
      <p>
        Usamos cookies para melhorar sua experiência de navegação e analisar o tráfego do site.
        Saiba mais em nossa&nbsp;<a href="/politica-cookies/" class="cookie-banner__link">política de cookies</a>.
      </p>
    </div>
    <div class="cookie-banner__actions">
      <button id="cookie-accept" class="cookie-btn cookie-btn--accept">
        Aceitar
      </button>
      <button id="cookie-reject" class="cookie-btn cookie-btn--outline">
        Apenas necessários
      </button>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background-color: var(--color-bg-card);
    border-top: 3px solid #7C3AED;
    border-top-color: var(--color-primary, #7C3AED);
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.12);
  }

  .cookie-banner__inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cookie-banner__text {
    flex: 1 1 280px;
  }

  .cookie-banner__text p {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .cookie-banner__link {
    color: var(--color-primary, #7C3AED);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .cookie-banner__link:hover {
    color: var(--color-primary-dark, #6D28D9);
  }

  .cookie-banner__actions {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .cookie-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1.125rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s, transform 0.1s;
    white-space: nowrap;
    border: 2px solid transparent;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .cookie-btn:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .cookie-btn--accept {
    background-color: #7C3AED;
    background-color: var(--color-primary, #7C3AED);
    color: #ffffff;
    border-color: transparent;
  }

  .cookie-btn--outline {
    background-color: transparent;
    color: var(--color-text-muted);
    border-color: var(--color-border);
  }

  .cookie-btn--outline:hover {
    border-color: var(--color-primary, #7C3AED);
    color: var(--color-primary, #7C3AED);
    opacity: 1;
  }

  @media (max-width: 480px) {
    .cookie-banner__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .cookie-banner__actions {
      width: 100%;
    }

    .cookie-btn {
      flex: 1;
      justify-content: center;
    }
  }
</style>

<script>
  (function () {
    const STORAGE_KEY = 'cookie_consent';
    const banner = document.getElementById('cookie-banner');
    const btnAccept = document.getElementById('cookie-accept');
    const btnReject = document.getElementById('cookie-reject');

    function hideBanner() {
      if (banner) {
        banner.style.display = 'none';
      }
    }

    // Only show if no consent stored yet
    const stored = localStorage.getItem(STORAGE_KEY);
    if (!stored && banner) {
      banner.style.display = 'block';
    }

    btnAccept?.addEventListener('click', () => {
      localStorage.setItem(STORAGE_KEY, 'accepted');
      hideBanner();
    });

    btnReject?.addEventListener('click', () => {
      localStorage.setItem(STORAGE_KEY, 'rejected');
      hideBanner();
    });
  })();
</script>
