---
interface RelatedVerse {
  ref: string;   // ex: "salmos/23"
  texto: string; // ex: "Salmo 23 — O Senhor é meu pastor"
}

interface Props {
  versiculos: RelatedVerse[];
}

const { versiculos } = Astro.props;
if (!versiculos || versiculos.length === 0) return;
---

<section class="mt-10" aria-labelledby="related-heading">
  <h2 id="related-heading" class="text-xl font-bold mb-5">
    Versículos relacionados
  </h2>

  <div class="grid gap-3 sm:grid-cols-2">
    {versiculos.map((v) => (
      <a
        href={`/biblia/${v.ref}`}
        class="flex items-start gap-3 p-4 rounded-xl border transition-all hover:-translate-y-0.5 hover:shadow-md"
        style="border-color: var(--color-border); background-color: var(--color-bg-card);"
      >
        <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center" style="background-color: var(--color-verse-bg);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--color-primary);">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <span class="text-sm font-medium leading-snug" style="color: var(--color-text);">{v.texto}</span>
      </a>
    ))}
  </div>
</section>
