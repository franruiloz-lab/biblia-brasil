      "numero": 1,
      "versoes": {
        "ARC": "Deus está na assembléia divina; julga no meio dos deuses:"
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 2,
      "versoes": {
        "ARC": "Até quando julgareis injustamente, e tereis respeito às pessoas dos ímpios?"
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 3,
      "versoes": {
        "ARC": "Fazei justiça ao pobre e ao órfão; procedei retamente com o aflito e o desamparado."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 4,
      "versoes": {
        "ARC": "Livrai o pobre e o necessitado, livrai-os das mãos dos ímpios."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 5,
      "versoes": {
        "ARC": "Eles nada sabem, nem entendem; andam vagueando às escuras; abalam-se todos os fundamentos da terra."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 6,
      "versoes": {
        "ARC": "Eu disse: Vós sois deuses, e filhos do Altíssimo, todos vós."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 7,
      "versoes": {
        "ARC": "Todavia, como homens, haveis de morrer e, como qualquer dos príncipes, haveis de cair."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 8,
      "versoes": {
        "ARC": "Levanta-te, ó Deus, julga a terra; pois a ti pertencem todas as nações."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    }
