  "capitulo": 115,
  "testamento": "AT",
  "titulo": "",
  "autor": "Davi e outros",
  "versiculos": [
    {
      "numero": 1,
      "versoes": {
        "ARC": "Não a nós, Senhor, não a nós, mas ao teu nome dá glória, por amor da tua benignidade e da tua verdade."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 2,
      "versoes": {
        "ARC": "Por que perguntariam as nações: Onde está o seu Deus?"
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 3,
      "versoes": {
        "ARC": "Mas o nosso Deus está nos céus; ele faz tudo o que lhe apraz."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 4,
      "versoes": {
        "ARC": "Os ídolos deles são prata e ouro, obra das mãos do homem."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 5,
      "versoes": {
        "ARC": "Têm boca, mas não falam; têm olhos, mas não vêem;"
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 6,
      "versoes": {
        "ARC": "têm ouvidos, mas não ouvem; têm nariz, mas não cheiram;"
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 7,
      "versoes": {
        "ARC": "têm mãos, mas não apalpam; têm pés, mas não andam; nem som algum sai da sua garganta."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 8,
      "versoes": {
        "ARC": "Semelhantes a eles sejam os que fazem, e todos os que neles confiam."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 9,
      "versoes": {
        "ARC": "Confia, ó Israel, no Senhor; ele é seu auxílio e seu escudo."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 10,
      "versoes": {
        "ARC": "Casa de Arão, confia no Senhor; ele é seu auxílio e seu escudo."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 11,
      "versoes": {
        "ARC": "Vós, os que temeis ao Senhor, confiai no Senhor; ele é seu auxílio e seu escudo."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 12,
      "versoes": {
        "ARC": "O Senhor tem-se lembrado de nós, abençoar-nos-á; abençoará a casa de Israel; abençoará a casa de Arão;"
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 13,
      "versoes": {
        "ARC": "abençoará os que temem ao Senhor, tanto pequenos como grandes."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 14,
      "versoes": {
        "ARC": "Aumente-vos o Senhor cada vez mais, a vós e a vossos filhos."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 15,
      "versoes": {
        "ARC": "Sede vós benditos do Senhor, que fez os céus e a terra."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 16,
      "versoes": {
        "ARC": "Os céus são os céus do Senhor, mas a terra, deu-a ele aos filhos dos homens."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 17,
      "versoes": {
        "ARC": "Os mortos não louvam ao Senhor, nem os que descem ao silêncio;"
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 18,
      "versoes": {
        "ARC": "nós, porém, bendiremos ao Senhor, desde agora e para sempre. Louvai ao Senhor."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    }
  ],
