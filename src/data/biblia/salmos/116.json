  "versiculos": [
    {
      "numero": 1,
      "versoes": {
        "ARC": "Amo ao Senhor, porque ele ouve a minha voz e a minha súplica."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 2,
      "versoes": {
        "ARC": "Porque inclina para mim o seu ouvido, invocá-lo-ei enquanto viver."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 3,
      "versoes": {
        "ARC": "Os laços da morte me cercaram; as angústias do Seol se apoderaram de mim; sofri tribulação e tristeza."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 4,
      "versoes": {
        "ARC": "Então invoquei o nome do Senhor, dizendo: Ó Senhor, eu te rogo, livra-me."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 5,
      "versoes": {
        "ARC": "Compassivo é o Senhor, e justo; sim, misericordioso é o nosso Deus."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 6,
      "versoes": {
        "ARC": "O Senhor guarda os simples; quando me acho abatido, ele me salva."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 7,
      "versoes": {
        "ARC": "Volta, minha alma, ao teu repouso, pois o Senhor te fez bem."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 8,
      "versoes": {
        "ARC": "Pois livraste a minha alma da morte, os meus olhos das lágrimas, e os meus pés de tropeçar."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 9,
      "versoes": {
        "ARC": "Andarei perante o Senhor, na terra dos viventes."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 10,
      "versoes": {
        "ARC": "Cri, por isso falei; estive muito aflito."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 11,
      "versoes": {
        "ARC": "Eu dizia na minha precipitação: Todos os homens são mentirosos."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 12,
      "versoes": {
        "ARC": "Que darei eu ao Senhor por todos os benefícios que me tem feito?"
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 13,
      "versoes": {
        "ARC": "Tomarei o cálice da salvação, e invocarei o nome do Senhor."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 14,
      "versoes": {
        "ARC": "Pagarei os meus votos ao Senhor, na presença de todo o seu povo."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 15,
      "versoes": {
        "ARC": "Preciosa é à vista do Senhor a morte dos seus santos."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 16,
      "versoes": {
        "ARC": "Ó Senhor, deveras sou teu servo; sou teu servo, filho da tua serva; soltaste as minhas cadeias."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 17,
      "versoes": {
        "ARC": "Oferecer-te-ei sacrifícios de ação de graças, e invocarei o nome do Senhor."
      },
      "temas": [],
      "versiculosRelacionados": [],
      "faq": []
    },
    {
      "numero": 18,
      "versoes": {
        "ARC": "Pagarei os meus votos ao Senhor, na presença de todo o seu povo,"
      },
      "temas": [],
