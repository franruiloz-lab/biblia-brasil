---
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import livros from '../../../data/livros.json';

export async function getStaticPaths() {
  return livros.map(livro => ({
    params: { livro: livro.slug },
    props: { livroData: livro }
  }));
}

const { livroData } = Astro.props;
const { livro } = Astro.params;

// Descubrir qué capítulos tienen datos
const modules = import.meta.glob('../../../data/biblia/**/*.json');
const capitulosComDados = new Set<number>();

for (const [path] of Object.entries(modules)) {
  const parts = path.split('/');
  const livroSlug = parts[parts.length - 2];
  const capNum = parseInt(parts[parts.length - 1].replace('.json', ''));
  if (livroSlug === livro && !isNaN(capNum)) {
    capitulosComDados.add(capNum);
  }
}

const title = `${livroData.nome} — Todos os Capítulos | Bíblia Brasil`;
const description = `Leia ${livroData.nome} completo em português. ${livroData.capitulos} capítulos com 4 versões (ARC, NVI, NTLH, NVT), explicações e versículos em destaque.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${livroData.nome} — Bíblia Sagrada`,
  "description": description,
  "url": `https://bibliabrasil.com.br/biblia/${livro}`,
  "inLanguage": "pt-BR"
};

const breadcrumbs = [
  { label: 'Início', href: '/' },
  { label: 'A Bíblia', href: '/biblia/' },
  { label: livroData.nome }
];

const capitulos = Array.from({ length: livroData.capitulos }, (_, i) => i + 1);
---

<Base title={title} description={description} schema={schema}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbs} />

    <header class="mb-10">
      <div class="ui-font text-sm font-semibold mb-2" style="color: var(--color-primary);">
        {livroData.testamento === 'AT' ? 'Antigo Testamento' : 'Novo Testamento'} · {livroData.abrev}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold mb-3">{livroData.nome}</h1>
      <p class="text-lg" style="color: var(--color-text-muted);">
        {livroData.capitulos} {livroData.capitulos === 1 ? 'capítulo' : 'capítulos'} · Bíblia Sagrada em português
      </p>
    </header>

    <!-- Grid de capítulos -->
    <section>
      <h2 class="text-xl font-bold mb-5">Capítulos</h2>
      <div class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 lg:grid-cols-10 gap-2">
        {capitulos.map(num => {
          const temDados = capitulosComDados.has(num);
          return (
            <a
              href={`/biblia/${livro}/${num}/`}
              class={`flex items-center justify-center h-12 rounded-xl text-sm font-semibold ui-font transition-all border ${
                temDados
                  ? 'hover:border-purple-500 hover:shadow-md'
                  : 'hover:border-purple-400'
              }`}
              style={
                temDados
                  ? `background-color: var(--color-primary-bg); color: var(--color-primary); border-color: var(--color-primary);`
                  : `background-color: var(--color-bg-card); color: var(--color-text); border-color: var(--color-border);`
              }
              title={temDados ? `${livroData.nome} ${num} — com explicação` : `${livroData.nome} ${num}`}
            >
              {num}
            </a>
          );
        })}
      </div>

      {capitulosComDados.size > 0 && (
        <div class="flex items-center gap-2 mt-5 ui-font text-xs" style="color: var(--color-text-muted);">
          <span class="w-4 h-4 rounded" style="background-color: var(--color-primary-bg); border: 1px solid var(--color-primary); display: inline-block;"></span>
          <span>Capítulos com versículos em destaque e explicação completa</span>
        </div>
      )}
    </section>

    <!-- Info do livro -->
    <aside class="mt-12 rounded-2xl p-6 border" style="border-color: var(--color-border); background-color: var(--color-bg-card);">
      <h2 class="text-lg font-bold mb-4">Sobre {livroData.nome}</h2>
      <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div>
          <dt class="ui-font text-xs" style="color: var(--color-text-muted);">Testamento</dt>
          <dd class="font-semibold text-sm mt-1" style="color: var(--color-text);">
            {livroData.testamento === 'AT' ? 'Antigo Testamento' : 'Novo Testamento'}
          </dd>
        </div>
        <div>
          <dt class="ui-font text-xs" style="color: var(--color-text-muted);">Abreviação</dt>
          <dd class="font-semibold text-sm mt-1" style="color: var(--color-text);">{livroData.abrev}</dd>
        </div>
        <div>
          <dt class="ui-font text-xs" style="color: var(--color-text-muted);">Capítulos</dt>
          <dd class="font-semibold text-sm mt-1" style="color: var(--color-text);">{livroData.capitulos}</dd>
        </div>
        <div>
          <dt class="ui-font text-xs" style="color: var(--color-text-muted);">Ordem na Bíblia</dt>
          <dd class="font-semibold text-sm mt-1" style="color: var(--color-text);">{livroData.ordem}º livro</dd>
        </div>
      </dl>
    </aside>

    <!-- Navegação entre livros -->
    <nav class="flex justify-between mt-10 ui-font" aria-label="Navegação entre livros">
      {(() => {
        const livroAnterior = livros.find(l => l.ordem === livroData.ordem - 1);
        const livroProximo = livros.find(l => l.ordem === livroData.ordem + 1);
        return (
          <>
            {livroAnterior && (
              <a
                href={`/biblia/${livroAnterior.slug}/`}
                class="flex items-center gap-2 px-4 py-2 rounded-xl border transition-colors hover:border-purple-400"
                style="border-color: var(--color-border);"
              >
                ← {livroAnterior.nome}
              </a>
            )}
            {livroProximo && (
              <a
                href={`/biblia/${livroProximo.slug}/`}
                class="flex items-center gap-2 px-4 py-2 rounded-xl border transition-colors hover:border-purple-400 ml-auto"
                style="border-color: var(--color-border);"
              >
                {livroProximo.nome} →
              </a>
            )}
          </>
        );
      })()}
    </nav>
  </div>
</Base>
