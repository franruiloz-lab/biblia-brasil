---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import temas from '../../data/temas.json';

const title = 'Versículos por Tema — Bíblia Sagrada | Bíblia Brasil';
const description = 'Encontre versículos bíblicos organizados por tema: proteção, fé, bênção, paz, amor, esperança, oração e sabedoria. Com 4 versões em português.';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Versículos por Tema",
  "description": description,
  "url": "https://bibliabrasil.com.br/temas",
  "inLanguage": "pt-BR"
};

const breadcrumbs = [
  { label: 'Início', href: '/' },
  { label: 'Temas' }
];
---

<Base title={title} description={description} schema={schema}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbs} />

    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold mb-3">Versículos por Tema</h1>
      <p class="text-lg max-w-2xl" style="color: var(--color-text-muted);">
        Encontre a Palavra certa para o momento certo. Versículos organizados pelos temas que mais importam na vida cristã.
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {temas.map(tema => (
        <a
          href={`/temas/${tema.slug}/`}
          class="block rounded-2xl p-6 border transition-all hover:border-purple-400 hover:shadow-md group"
          style="border-color: var(--color-border); background-color: var(--color-bg-card);"
        >
          <div class="text-3xl mb-3">{tema.icone}</div>
          <h2 class="text-xl font-bold mb-2 group-hover:text-purple-600 transition-colors" style="color: var(--color-text);">
            {tema.nome}
          </h2>
          <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-muted);">
            {tema.descricao}
          </p>
          <div class="ui-font text-xs font-semibold" style="color: var(--color-primary);">
            {tema.versiculos.length} versículos selecionados →
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
